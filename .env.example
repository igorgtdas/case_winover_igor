# =============================================================================
# AtlasShop Assist — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# Chave de API Groq
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Chave de API OpenAI (necessária apenas se usar provider=openai em algum agente)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# =============================================================================
# Guard Agent — filtro de segurança (deve ser rápido e determinístico)
# PROVIDER: groq | openai
# =============================================================================
GUARD_PROVIDER=groq
GUARD_MODEL=llama-3.1-8b-instant
GUARD_TEMPERATURE=0
GUARD_TOP_P=1.0
GUARD_MAX_TOKENS=256
GUARD_CONTEXT_WINDOW=0

# =============================================================================
# Router Agent — classificador de intenção
# PROVIDER: groq | openai
# =============================================================================
ROUTER_PROVIDER=groq
ROUTER_MODEL=llama-3.1-8b-instant
ROUTER_TEMPERATURE=0
ROUTER_TOP_P=1.0
ROUTER_MAX_TOKENS=256
ROUTER_CONTEXT_WINDOW=5

# =============================================================================
# Knowledge Agent — especialista em base de conhecimento
# PROVIDER: groq | openai
# Exemplo OpenAI: KNOWLEDGE_PROVIDER=openai / KNOWLEDGE_MODEL=gpt-4o
# =============================================================================
KNOWLEDGE_PROVIDER=groq
KNOWLEDGE_MODEL=llama-3.3-70b-versatile
KNOWLEDGE_TEMPERATURE=0.1
KNOWLEDGE_TOP_P=1.0
KNOWLEDGE_MAX_TOKENS=1024
KNOWLEDGE_CONTEXT_WINDOW=5

# =============================================================================
# Data Agent — especialista em consultas SQL
# PROVIDER: groq | openai
# Exemplo OpenAI: DATA_PROVIDER=openai / DATA_MODEL=gpt-4o
# =============================================================================
DATA_PROVIDER=groq
DATA_MODEL=llama-3.3-70b-versatile
DATA_TEMPERATURE=0
DATA_TOP_P=1.0
DATA_MAX_TOKENS=1024
DATA_CONTEXT_WINDOW=5

# =============================================================================
# Escalation Agent — avalia escalonamento
# PROVIDER: groq | openai
# =============================================================================
ESCALATION_PROVIDER=groq
ESCALATION_MODEL=llama-3.3-70b-versatile
ESCALATION_TEMPERATURE=0
ESCALATION_TOP_P=1.0
ESCALATION_MAX_TOKENS=512
ESCALATION_CONTEXT_WINDOW=0

# =============================================================================
# LangSmith — observability e tracing (opcional)
# Documentação: https://docs.smith.langchain.com
# Chave de API: https://smith.langchain.com (Settings → API Keys)
# =============================================================================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=atlasshop-assist
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # padrão, não precisa mudar

# =============================================================================
# Infraestrutura
# =============================================================================
DB_PATH=atlasshop.db
KNOWLEDGE_DIR=knowledge
